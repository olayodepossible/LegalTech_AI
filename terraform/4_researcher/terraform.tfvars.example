# Part 4: Researcher Agent Configuration
# Copy this file to terraform.tfvars and update with your values

# Your AWS region for App Runner (can be any region with App Runner support)
aws_region = "us-east-1"

# Your OpenAI API key (get from https://platform.openai.com/api-keys)
openai_api_key = "sk-..."

# API endpoint and key (must match variable names in variables.tf)
legal_api_endpoint = "https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com/prod/ingest"
legal_api_key = "your-api-key-here"

# OpenRouter (align with root .env OPENROUTER_API_KEY)
openrouter_api_key = "sk-or-..."

# OpenRouter / LiteLLM model short id (see backend/researcher/research_evaluation.py)
# openai_chat_model = "gpt-4.1-mini"

# Optional: Serper.dev — enables the Google-search refinement pass (same as root .env SERPER_API_KEY)
# serper_api_key = "..."